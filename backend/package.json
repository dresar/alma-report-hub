{
  "name": "sira-backend",
  "version": "1.0.0",
  "private": true,
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch server.js",
    "build": "npx esbuild server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=app.js --external:postgres --external:bcryptjs --external:jsonwebtoken --external:express --external:cors --external:dotenv",
    "build:full": "npx esbuild server.ts --bundle --platform=node --target=node20 --format=cjs --outfile=app.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
